rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Blueprints ---

    function isValidUser(data) {
      return data.keys().hasAll(['userId', 'email', 'createdAt', 'updatedAt']) 
        && data.keys().size() <= 6
        && data.userId == request.auth.uid
        && data.email is string && data.email.size() <= 256
        && data.createdAt is timestamp && data.updatedAt is timestamp;
    }

    function isValidBook(data) {
      return data.keys().hasAll(['id', 'ownerId', 'title', 'addedAt'])
        && data.keys().size() <= 8
        && data.id is string && data.id.size() <= 128
        && data.ownerId == request.auth.uid
        && data.title is string && data.title.size() <= 512
        && data.addedAt is number;
    }

    function isValidChunk(data) {
      return data.keys().hasAll(['bookId', 'chunkIndex', 'data'])
        && data.keys().size() == 3
        && data.bookId is string && data.data is string && data.data.size() <= 1048576 
        && data.chunkIndex is number;
    }

    function isValidTranslation(data) {
      return data.keys().hasAll(['bookId', 'chapterId', 'originalText', 'translatedText', 'language'])
        && data.keys().size() <= 7
        && data.bookId is string && data.chapterId is string 
        && data.originalText is string && data.translatedText is string
        && data.language is string;
    }

    // --- Match Blocks ---

    // User profiles
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().createdAt == request.time;
      allow update: if isOwner(userId) && isValidUser(incoming()) 
        && incoming().diff(existing()).affectedKeys().hasOnly(['email', 'displayName', 'settings', 'updatedAt'])
        && incoming().updatedAt == request.time;
      
      // User's books
      match /books/{bookId} {
        allow list, get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidBook(incoming()) && isValidId(bookId);
        allow update: if isOwner(userId) && isValidBook(incoming()) 
          && incoming().diff(existing()).affectedKeys().hasOnly(['title', 'author', 'cover', 'updatedAt'])
          && incoming().id == existing().id;
        allow delete: if isOwner(userId);

        // Content chunks for the book
        match /chunks/{chunkId} {
          allow list, get: if isOwner(userId);
          allow create: if isOwner(userId) && isValidChunk(incoming()) && isValidId(chunkId);
          allow delete: if isOwner(userId);
        }

        // Stored translations for the book
        match /translations/{translationId} {
          allow list, get: if isOwner(userId);
          allow create: if isOwner(userId) && isValidTranslation(incoming()) && isValidId(translationId);
          allow update: if isOwner(userId) && isValidTranslation(incoming())
            && incoming().diff(existing()).affectedKeys().hasOnly(['translatedText', 'updatedAt']);
          allow delete: if isOwner(userId);
        }
      }
    }
  }
}
